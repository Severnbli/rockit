{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "a2f4fafe5b8e4df69a57d4df6e7ec869",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "GlitchEffect (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": 275.1999816894531,
            "y": -151.1999969482422,
            "width": 221.60006713867188,
            "height": 220.80003356933595
        }
    },
    "m_Slots": [
        {
            "m_Id": "f466fda3b95c450591023d32666dc2eb"
        },
        {
            "m_Id": "3b6124901c944b138b61d90aafb94196"
        },
        {
            "m_Id": "dbd0c0b04e86443688412803605d03c4"
        },
        {
            "m_Id": "fe0eb83a236b432c8824347b7fcd7676"
        },
        {
            "m_Id": "4ab8593ed1954baba9ef7af424cde0a8"
        },
        {
            "m_Id": "1b20f78ed658496c8294d5521a569035"
        },
        {
            "m_Id": "43a6f33be9024b839115bba75d20dd4c"
        },
        {
            "m_Id": "f31cb6c5beb045578ddb9cde45c8fb8c"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "GlitchEffect",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float2 uv  = UV;\nfloat uvR = uv.x + Amount;\nfloat uvB = uv.x - Amount;\n\nif (EnableFrame)\n{\n    float frameShift = sin(uv.y * 10.0 + _Time.y)\n                     * step(0.3, sin(_Time.y + 4.0 * _CosTime.w))\n                     * Frame;\n    uv.x += frameShift;\n    uvR  += frameShift;\n    uvB  += frameShift;\n}\n\nif (EnablePixel)\n{\n    float4 uv1a = floor(float4(UV * float2(24.0, 9.0),\n                                UV * float2(8.0,  4.0)));\n\n    float rA = frac(sin(dot(uv1a.xy * floor(_Time.y * 12.0), float2(127.1, 311.7))) * 43758.5453123);\n    float rB = frac(sin(dot(uv1a.zw * floor(_Time.y * 12.0), float2(127.1, 311.7))) * 43758.5453123);\n\n    float lineNoise = pow(rA, 8.0) * pow(rB, 3.0);\n    uv.x  += lineNoise * PixelX;\n    uvB   -= lineNoise * PixelY;\n}\n\nfloat r = SAMPLE_TEXTURE2D_X(_BlitTexture, sampler_LinearClamp, float2(uvR, uv.y)).r;\nfloat g = SAMPLE_TEXTURE2D_X(_BlitTexture, sampler_LinearClamp, uv).g;\nfloat b = SAMPLE_TEXTURE2D_X(_BlitTexture, sampler_LinearClamp, float2(uvB, uv.y)).b;\n\nColor = float4(r, g, b, 1.0);"
}

